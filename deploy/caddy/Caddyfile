# Caddy reverse proxy for ChronoNode REST API
# Deploy: /etc/caddy/Caddyfile or /etc/caddy/sites/chrononode
# See deploy/caddy/README.md for installation instructions.

chrono.baals.network {
    # Reverse proxy to ChronoNode API (default port 8080)
    reverse_proxy localhost:8080

    # JSON access logs
    log {
        output file /var/log/caddy/chrononode-api.log {
            roll_size 10MiB
            roll_keep 5
            roll_keep_for 720h
        }
        format json
    }

    # Automatic TLS via Let's Encrypt
    tls {
        protocols tls1.3
    }

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}
