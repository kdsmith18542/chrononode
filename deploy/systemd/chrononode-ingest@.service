[Unit]
Description=ChronoNode ingest loop (%i)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=chrononode
Group=chrononode
Environment=XDG_DATA_HOME=/var/lib
EnvironmentFile=-/etc/chrononode/chrononode.env
ExecStart=/usr/local/bin/chrononode ingest --chain %i --from 0 --follow
Restart=always
RestartSec=5
LimitNOFILE=1048576
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
