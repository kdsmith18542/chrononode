# ChronoNode runtime environment (single VPS baseline)
# Copy to: /etc/chrononode/chrononode.env

# Storage backend: local_fs, ipfs, pinata
CHRONONODE_STORAGE_BACKEND=local_fs

# API key (optional)
# CHRONONODE_API_KEY=replace-with-strong-secret

# IPFS settings (used when CHRONONODE_STORAGE_BACKEND=ipfs)
CHRONONODE_IPFS_API_URL=http://127.0.0.1:5001

# Pinata settings (used when CHRONONODE_STORAGE_BACKEND=pinata)
# CHRONONODE_PINATA_JWT=replace-with-pinata-jwt
CHRONONODE_PINATA_API_BASE=https://api.pinata.cloud
CHRONONODE_PINATA_GATEWAY_BASE=https://gateway.pinata.cloud
