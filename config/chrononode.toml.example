[verification]
checkpoint_size = 1000
hash_algorithm = "sha256"

[api]
port = 8080
api_key = "your-secret-api-key-here"

[api.rate_limiting]
requests_per_second = 100
burst_size = 200

[storage]
backend = "local_fs"
# backend = "ipfs"
# backend = "pinata"
base_path = "./data"

[index]
db_path = "./data/index.db"

[logging]
level = "info"
format = "json"

[metrics]
enabled = true
port = 9090

[adapters.baals]
url = "http://localhost:9070"

# --- Dormancy Detection (Phase 3) ---
[dormancy]
# Default threshold in blocks before an address is considered dormant
# 26280 blocks ≈ 5 years for Bitcoin (10-min blocks)
default_threshold_blocks = 26280

# Per-chain overrides
[dormancy.chain_thresholds]
# bitcoin = 26280
# dogecoin = 2103840  # ~4 years (1-min blocks)

# --- Attestation Submission (Phase 4) ---
[attestation]
# BaaLS API endpoint for submitting dormancy attestations
# baals_api_url = "http://localhost:18080"

# Path to the BaaLS account ed25519 key file (32 bytes raw seed)
# baals_key_path = "/etc/chrononode/baals.key"

# Automatically submit attestation when new dormant addresses are detected
auto_submit = true

# EVM RPC endpoint for Resurgence RewardDistributor (Arbitrum Sepolia testnet)
# evm_rpc_url = "https://sepolia-rollup.arbitrum.io/rpc"

# Resurgence RewardDistributor contract address
# evm_contract_address = "0x9769038aCbD727C41cF29102BB012Ee735BD2cdd"

# Hex-encoded secp256k1 private key for signing EVM transactions (no 0x prefix)
# Keep this file readable only by the chrononode user (chmod 600)
# evm_private_key = "your-64-char-hex-private-key"

# EVM chain ID — 421614 for Arbitrum Sepolia, 42161 for Arbitrum One
# evm_chain_id = 421614

# Gas limit for EVM dormancy proof submission (default: 1_000_000)
# evm_gas_limit = 1_000_000
