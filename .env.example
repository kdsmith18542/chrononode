# ChronoNode Configuration
# Copy this file to .env and adjust values

# Chain to ingest/serve
CHRONONODE_CHAIN=mock

# Storage backend: local_fs, ipfs, pinata
CHRONONODE_STORAGE_BACKEND=local_fs

# IPFS configuration (when using ipfs backend)
CHRONONODE_IPFS_API_URL=http://ipfs:5001

# Pinata configuration (when using pinata backend)
CHRONONODE_PINATA_API_BASE=https://api.pinata.cloud
CHRONONODE_PINATA_GATEWAY_BASE=https://gateway.pinata.cloud
CHRONONODE_PINATA_JWT=

# Index backend: sqlite, postgres
CHRONONODE_INDEX_BACKEND=sqlite

# PostgreSQL connection (when using postgres backend)
CHRONONODE_POSTGRES_URL=postgres://chrononode:chrononode@postgres:5432/chrononode

# API configuration
CHRONONODE_API_KEY=
CHRONONODE_RATE_LIMIT=100
